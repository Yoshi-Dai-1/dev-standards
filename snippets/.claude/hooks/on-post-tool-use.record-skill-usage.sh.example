#!/bin/bash
# on-post-tool-use.record-skill-usage.sh.example
# PostToolUseイベント：スキル実行後に使用履歴を skill-usage.md に記録するHook
#
# セットアップ：
#   1. このファイルを .example を外してコピーする
#      cp on-post-tool-use.record-skill-usage.sh.example \
#         on-post-tool-use.record-skill-usage.sh
#   2. chmod +x on-post-tool-use.record-skill-usage.sh
#   3. .claude/settings.json の hooks に登録する（下記参照）
#
# settings.json への登録例：
#   {
#     "hooks": {
#       "PostToolUse": [
#         {
#           "matcher": "Skill",
#           "hooks": [{ "type": "command",
#                       "command": ".claude/hooks/on-post-tool-use.record-skill-usage.sh" }]
#         }
#       ]
#     }
#   }
#
# matcher について：
#   Claude Code がスキルを実行するとき、tool_name は "Skill" になります。
#   matcher: "Skill" と指定することで、スキル実行時のみこのHookが発火します。
#   （Hookのmatcherは大文字小文字を区別するため "Skill" と正確に記載すること）
#
# スキル名の取得について：
#   tool_input 内のスキル名フィールドは Claude Code のバージョンにより変わる可能性があります。
#   初回セットアップ後、以下のデバッグ手順で実際のフィールド名を確認してください。
#
# デバッグ手順（初回セットアップ時に実施）：
#   1. 一時的にこのスクリプトの先頭に以下を追加する：
#        cat >> /tmp/skill-hook-debug.log
#   2. スキルを実行して /tmp/skill-hook-debug.log の内容を確認する
#   3. tool_input 内のスキル名フィールド名を特定して SKILL_NAME_FIELDS を更新する
#   4. 確認後、デバッグ行を削除する

DATE=$(date +%Y-%m-%d)
USAGE_FILE=".claude/usage/skill-usage.md"

# stdinからツール情報を読み取る
INPUT=$(cat)

# tool_name を取り出す
if command -v python3 &>/dev/null; then
  TOOL_NAME=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('tool_name', ''))
except Exception:
    print('')
" 2>/dev/null)
else
  TOOL_NAME=$(echo "$INPUT" | grep -o '"tool_name"[[:space:]]*:[[:space:]]*"[^"]*"' \
              | sed 's/.*"\([^"]*\)".*/\1/' | tail -1)
fi

# "Skill" ツール以外はスキップ（matcherで絞り込まれるが念のため二重チェック）
if [ "$TOOL_NAME" != "Skill" ]; then
  exit 0
fi

# スキル名を取り出す
# tool_input 内の候補フィールドを優先順に試みる
# ※ 実際のフィールド名はデバッグ手順で確認してから調整すること
if command -v python3 &>/dev/null; then
  SKILL_NAME=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    inp = d.get('tool_input', {})
    # 候補フィールドを優先順に試みる（実際のフィールド名に合わせて調整）
    name = (inp.get('name')
            or inp.get('skill_name')
            or inp.get('skill')
            or inp.get('id')
            or '')
    print(name)
except Exception:
    print('')
" 2>/dev/null)
fi

# スキル名が取得できなかった場合はログに残してスキップ
if [ -z "$SKILL_NAME" ]; then
  echo "[$DATE] WARNING: skill name could not be resolved. Run debug procedure." \
    >> /tmp/skill-hook-debug.log
  exit 0
fi

# skill-usage.md が存在しない場合は作成しない（setup-harness.sh が初期化済みのはず）
if [ ! -f "$USAGE_FILE" ]; then
  exit 0
fi

# 使用履歴を追記（ローカル・グローバルスキル問わず同じ形式で記録）
echo "- $DATE: $SKILL_NAME" >> "$USAGE_FILE"

exit 0
