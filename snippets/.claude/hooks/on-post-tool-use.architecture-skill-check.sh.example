#!/bin/bash
# on-post-tool-use.architecture-skill-check.sh.example
#
# 目的：ARCHITECTURE.md の技術スタックセクションが変更されたとき、
#       外部スキル診断を促すフィードバックをAIに送る。
#
# 発火条件：PostToolUse（Write / Edit / MultiEdit ツール実行後）
#
# 使い方：
#   1. このファイルを .example を外してコピーする
#      cp on-post-tool-use.architecture-skill-check.sh.example \
#         on-post-tool-use.architecture-skill-check.sh
#   2. chmod +x on-post-tool-use.architecture-skill-check.sh
#   3. .claude/settings.json の hooks に登録する（README.md 参照）
#
# 終了コード：
#   0 = 通常終了（フィードバックなし）
#   2 = AIへのフィードバックあり（stderr の内容がAIに渡る）

INPUT=$(cat)

# 編集されたファイルのパスを取得
FILE_PATH=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    # Write / Edit / MultiEdit それぞれのフィールド名に対応
    path = (
        d.get('tool_input', {}).get('file_path') or
        d.get('tool_input', {}).get('path') or
        ''
    )
    print(path)
except Exception:
    print('')
" 2>/dev/null)

# ARCHITECTURE.md の編集でなければスキップ
if [[ "$FILE_PATH" != *"ARCHITECTURE.md" ]]; then
  exit 0
fi

# 技術スタックセクションが記入済みか確認
# 「| フレームワーク |」行が存在し、かつプレースホルダーが残っていなければ記入済みと判断
if ! grep -q "| フレームワーク |" "$FILE_PATH" 2>/dev/null; then
  exit 0
fi
if grep -q "\[React + Vite" "$FILE_PATH" 2>/dev/null; then
  # プレースホルダーのまま（未記入）
  exit 0
fi

# find-skills がインストールされているか確認
FIND_SKILLS_PATH=$(find .claude/skills ~/.claude/skills -name "SKILL.md" -path "*/find-skills/*" 2>/dev/null | head -1)
if [ -z "$FIND_SKILLS_PATH" ]; then
  # find-skills 未インストールの場合は診断不要
  exit 0
fi

# AIにフィードバックを送る（終了コード2）
cat >&2 <<'EOF'
ARCHITECTURE.md の技術スタックセクションが変更されました。

find-skills スキルを使って、変更後の技術スタックに対応する外部スキルを診断してください。
（ARCHITECTURE.md の Step 5-A に従って実行する）
EOF

exit 2
