#!/bin/bash
# on-pre-tool-use.check-secrets.sh.example
# PreToolUseイベント：Bashツール実行前に機密情報の混入を検出するHook
#
# セットアップ：
#   1. このファイルを on-pre-tool-use.check-secrets.sh にコピー
#      cp on-pre-tool-use.check-secrets.sh.example \
#         on-pre-tool-use.check-secrets.sh
#   2. chmod +x on-pre-tool-use.check-secrets.sh
#   3. .claude/settings.json の hooks に登録する（下記参照）
#
# settings.json への登録例：
#   {
#     "hooks": {
#       "PreToolUse": [
#         {
#           "matcher": "Bash",
#           "hooks": [{ "type": "command",
#                       "command": ".claude/hooks/on-pre-tool-use.check-secrets.sh" }]
#         }
#       ]
#     }
#   }
#
# Claude Code Hooks について：
#   PreToolUseイベントはClaude CodeがBashツールを実行する直前に発火します。
#   終了コード2を返すとツールの実行をブロックし、stderrの内容をエージェントに伝えます。
#
# 終了コード：
#   0 = 正常（Bashツールの実行を許可）
#   2 = ブロック（stderrの内容をClaude Codeがエージェントにフィードバックし中止）
#
# 注意：
#   このHookはClaude CodeがBashで git commit を実行するときに発火します。
#   人間が手動で git commit を実行する場合は発火しません。
#   人間のコミットも保護したい場合は、git標準のpre-commit hookを
#   .git/hooks/pre-commit に別途設置してください。

echo "🔒 セキュリティチェック中..."

PATTERNS=(
  "API_KEY\s*="
  "SECRET\s*="
  "PASSWORD\s*="
  "PRIVATE_KEY"
  "Bearer [a-zA-Z0-9]"
)

FOUND=0
for PATTERN in "${PATTERNS[@]}"; do
  MATCHES=$(git diff --cached --name-only 2>/dev/null \
            | xargs grep -l "$PATTERN" 2>/dev/null \
            | grep -v "\.env" \
            | grep -v "\.example")
  if [ -n "$MATCHES" ]; then
    echo "⚠️  WARNING: 機密情報の可能性があるパターンを検出" >&2
    echo "   パターン: $PATTERN" >&2
    echo "   ファイル: $MATCHES" >&2
    FOUND=1
  fi
done

if [ $FOUND -eq 1 ]; then
  echo "" >&2
  echo "❌ コミットをブロックしました。上記のファイルを確認してください。" >&2
  exit 2
fi

echo "✅ セキュリティチェック通過"
exit 0
