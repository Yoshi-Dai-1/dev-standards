#!/bin/bash
# on-post-tool-use.lint-and-typecheck.sh.example
# PostToolUseイベント：ファイル書き込み・編集ツール実行後にlint・型チェックを自動実行するHook
#
# セットアップ：
#   1. このファイルを on-post-tool-use.lint-and-typecheck.sh にコピー
#   2. 実行権限を付与: chmod +x .claude/hooks/on-post-tool-use.lint-and-typecheck.sh
#   3. Claude Codeの設定でPostToolUseイベントに登録
#      対象ツール：Write（ファイル書き込み）・Edit（ファイル編集）
#
# Claude Codeのシステムは、Hookが終了コード2を返すとエージェントにフィードバックを送る。
# 終了コード0：正常終了（エージェントは続行）
# 終了コード2：エラー（エージェントにstderrの内容を伝えて修正を促す）
#
# 動作の仕組み：
#   PostToolUseイベント発火時、Claude CodeはHookのstdinにJSON形式でツール情報を渡す。
#   このスクリプトはファイルパスを取り出し、拡張子に応じたチェックを実行する。
#
# 設定：プロジェクトに合わせて以下の変数を変更する
ENABLE_TYPECHECK=true    # TypeScriptプロジェクトの場合true
ENABLE_LINT=true         # ESLint/Ruffを使う場合true
TYPECHECK_CMD="pnpm typecheck"   # 型チェックコマンド
LINT_CMD="pnpm lint"             # lintコマンド

# stdinからツール情報を読み取る（Claude CodeがJSON形式で渡す）
INPUT=$(cat)
TOOL_NAME=$(echo "$INPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tool_name',''))" 2>/dev/null)
FILE_PATH=$(echo "$INPUT" | python3 -c "import sys,json; d=json.load(sys.stdin); inp=d.get('tool_input',{}); print(inp.get('file_path', inp.get('path','')))" 2>/dev/null)

# ファイル編集系ツール以外はスキップ
if [[ "$TOOL_NAME" != "write_file" && "$TOOL_NAME" != "str_replace_based_edit_tool" && "$TOOL_NAME" != "create_file" ]]; then
  exit 0
fi

# 編集対象ファイルが存在しない・パスが空の場合はスキップ
if [ -z "$FILE_PATH" ] || [ ! -f "$FILE_PATH" ]; then
  exit 0
fi

ERRORS=""

# TypeScript / JavaScript ファイルの場合
if [[ "$FILE_PATH" =~ \.(ts|tsx|js|jsx)$ ]]; then
  # 型チェック
  if [ "$ENABLE_TYPECHECK" = true ] && command -v pnpm &>/dev/null; then
    TSC_OUT=$($TYPECHECK_CMD 2>&1)
    TSC_EXIT=$?
    if [ $TSC_EXIT -ne 0 ]; then
      ERRORS="${ERRORS}[型チェックエラー]\n${TSC_OUT}\n\n"
    fi
  fi

  # Lint
  if [ "$ENABLE_LINT" = true ] && command -v pnpm &>/dev/null; then
    LINT_OUT=$($LINT_CMD "$FILE_PATH" 2>&1)
    LINT_EXIT=$?
    if [ $LINT_EXIT -ne 0 ]; then
      ERRORS="${ERRORS}[Lintエラー]\n${LINT_OUT}\n\n"
    fi
  fi
fi

# Python ファイルの場合
if [[ "$FILE_PATH" =~ \.py$ ]]; then
  if command -v ruff &>/dev/null; then
    RUFF_OUT=$(ruff check "$FILE_PATH" 2>&1)
    RUFF_EXIT=$?
    if [ $RUFF_EXIT -ne 0 ]; then
      ERRORS="${ERRORS}[Ruff lintエラー]\n${RUFF_OUT}\n\n"
    fi
  fi
fi

# エラーがあれば終了コード2で返す（Claude Codeがエージェントにフィードバック）
if [ -n "$ERRORS" ]; then
  echo -e "$ERRORS" >&2
  exit 2
fi

exit 0
