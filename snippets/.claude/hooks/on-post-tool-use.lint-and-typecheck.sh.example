#!/bin/bash
# on-post-tool-use.lint-and-typecheck.sh.example
# PostToolUseイベント：ファイル書き込み・編集ツール実行後にlint・型チェックを自動実行するHook
#
# セットアップ：
#   1. このファイルを on-post-tool-use.lint-and-typecheck.sh にコピー
#      cp on-post-tool-use.lint-and-typecheck.sh.example \
#         on-post-tool-use.lint-and-typecheck.sh
#   2. chmod +x on-post-tool-use.lint-and-typecheck.sh
#   3. .claude/settings.json の hooks に登録する（下記参照）
#
# settings.json への登録例：
#   {
#     "hooks": {
#       "PostToolUse": [
#         {
#           "matcher": "Write|Edit|MultiEdit",
#           "hooks": [{ "type": "command",
#                       "command": ".claude/hooks/on-post-tool-use.lint-and-typecheck.sh" }]
#         }
#       ]
#     }
#   }
#
# Claude Code Hooks について：
#   Claude Code Hooksは Claude Code のライフサイクルイベントに発火するシェルスクリプトです。
#   Git hooks（.git/hooks/）とは別の仕組みです。
#   設定は .claude/settings.json（プロジェクト固有）または ~/.claude/settings.json（グローバル）で行います。
#
# 終了コード：
#   0 = 正常終了（Claude Codeは続行）
#   2 = エラー（stderrの内容をClaude Codeがエージェントにフィードバック）
#
# 設定：プロジェクトに合わせて以下の変数を変更する
ENABLE_TYPECHECK=true          # TypeScriptプロジェクトの場合true
ENABLE_LINT=true               # ESLint/Ruffを使う場合true
TYPECHECK_CMD="pnpm typecheck" # AGENTS.mdのType checkコマンドに合わせる
LINT_CMD="pnpm lint"           # AGENTS.mdのLintコマンドに合わせる

# stdinからツール情報を読み取る
INPUT=$(cat)

# ファイルパスを取り出す
if command -v python3 &>/dev/null; then
  FILE_PATH=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    inp = d.get('tool_input', {})
    print(inp.get('file_path') or inp.get('path') or '')
except Exception:
    print('')
" 2>/dev/null)
fi

# ファイルパスが空の場合はスキップ
if [ -z "$FILE_PATH" ] || [ ! -f "$FILE_PATH" ]; then
  exit 0
fi

ERRORS=""

# TypeScript / JavaScript ファイルの場合
if [[ "$FILE_PATH" =~ \.(ts|tsx|js|jsx)$ ]]; then
  if [ "$ENABLE_TYPECHECK" = true ] && command -v pnpm &>/dev/null; then
    TSC_OUT=$($TYPECHECK_CMD 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[型チェックエラー]\n${TSC_OUT}\n\n"
    fi
  fi
  if [ "$ENABLE_LINT" = true ] && command -v pnpm &>/dev/null; then
    LINT_OUT=$($LINT_CMD "$FILE_PATH" 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[Lintエラー]\n${LINT_OUT}\n\n"
    fi
  fi
fi

# Python ファイルの場合
if [[ "$FILE_PATH" =~ \.py$ ]]; then
  if command -v ruff &>/dev/null; then
    RUFF_OUT=$(ruff check "$FILE_PATH" 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[Ruff lintエラー]\n${RUFF_OUT}\n\n"
    fi
  fi
fi

if [ -n "$ERRORS" ]; then
  echo -e "$ERRORS" >&2
  exit 2
fi

exit 0
