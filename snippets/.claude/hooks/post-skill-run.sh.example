#!/bin/bash
# post-skill-run.sh.example
# スキル実行後に使用履歴を自動記録するHook
#
# セットアップ：
#   1. このファイルを post-skill-run.sh にコピー
#   2. 実行権限を付与: chmod +x .claude/hooks/post-skill-run.sh
#   3. Claude Codeの設定でPostToolUseイベントに登録
#
# 動作の仕組み：
#   Claude CodeはPostToolUseイベント発火時、Hookのstdinに以下のJSON形式でツール情報を渡す。
#   {
#     "tool_name": "実行されたツール名",
#     "tool_input": { ... },
#     "tool_response": { ... }
#   }
#   このスクリプトはtool_nameを読み取り、スキル呼び出しを検出して記録する。
#
# 初回セットアップ時の確認手順：
#   スキル実行時に実際に渡されるtool_nameをログで確認してから
#   以下の SKILL_TOOL_PATTERN を実際の値に合わせて調整すること。
#   確認用コマンド（一時的に使用）：
#   $ cat >> /tmp/hook-debug.log  ← stdinの内容をログに記録して確認する

# 設定：スキル呼び出しと判定するtool_nameのパターン（環境に合わせて変更する）
SKILL_TOOL_PATTERN="skill"

DATE=$(date +%Y-%m-%d)
USAGE_FILE=".claude/usage/skill-usage.md"

# stdinからツール情報を読み取る
INPUT=$(cat)

# tool_nameを取り出す
if command -v python3 &>/dev/null; then
  TOOL_NAME=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('tool_name', ''))
except Exception:
    print('')
" 2>/dev/null)
else
  TOOL_NAME=$(echo "$INPUT" | grep -o '"tool_name"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\([^"]*\)".*/\1/' | tail -1)
fi

# スキル呼び出しでなければスキップ
if [[ "$TOOL_NAME" != *"$SKILL_TOOL_PATTERN"* ]]; then
  exit 0
fi

# スキル名を取り出す
if command -v python3 &>/dev/null; then
  SKILL_NAME=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    inp = d.get('tool_input', {})
    name = inp.get('skill_name') or inp.get('name') or inp.get('command', '')
    print(name)
except Exception:
    print('')
" 2>/dev/null)
fi

# スキル名が取得できなかった場合はtool_nameで代替
if [ -z "$SKILL_NAME" ]; then
  SKILL_NAME="$TOOL_NAME"
fi

# 使用履歴ファイルに追記
if [ -f "$USAGE_FILE" ]; then
  echo "- $DATE: $SKILL_NAME" >> "$USAGE_FILE"
fi

# SKILL.mdのメタデータを更新（ファイルが存在する場合のみ）
SKILL_FILE=".claude/skills/$SKILL_NAME/SKILL.md"
if [ -f "$SKILL_FILE" ]; then
  # クロスプラットフォーム対応のsed（macOS・Linux両対応）
  if sed --version 2>/dev/null | grep -q "GNU"; then
    sed -i "s/last_used: .*/last_used: $DATE/" "$SKILL_FILE"
    CURRENT_COUNT=$(grep "use_count:" "$SKILL_FILE" | grep -o '[0-9]*' | head -1)
    CURRENT_COUNT=${CURRENT_COUNT:-0}
    NEW_COUNT=$((CURRENT_COUNT + 1))
    sed -i "s/use_count: .*/use_count: $NEW_COUNT/" "$SKILL_FILE"
  else
    sed -i '' "s/last_used: .*/last_used: $DATE/" "$SKILL_FILE"
    CURRENT_COUNT=$(grep "use_count:" "$SKILL_FILE" | grep -o '[0-9]*' | head -1)
    CURRENT_COUNT=${CURRENT_COUNT:-0}
    NEW_COUNT=$((CURRENT_COUNT + 1))
    sed -i '' "s/use_count: .*/use_count: $NEW_COUNT/" "$SKILL_FILE"
  fi
fi

exit 0
