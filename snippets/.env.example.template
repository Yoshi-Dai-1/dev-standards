# .env.example
# このファイルはコミットする（SSOTとして機能するため）
# 実際の値は書かない。変数名と説明だけ書く。
# 使い方：このファイルをコピーして .env を作り、値を埋める
#   $ cp .env.example .env

# ===== アプリケーション =====
NODE_ENV=development           # development | production | test
PORT=3000                      # サーバーのポート番号

# ===== データベース =====
DATABASE_URL=                  # 例: postgresql://user:pass@localhost:5432/dbname

# ===== 外部API =====
# API_KEY=                     # 外部APIキー（本番はCI/CDシークレットで管理）

# ===== 認証 =====
# JWT_SECRET=                  # JWTの署名キー（本番は十分な長さのランダム文字列）
# JWT_EXPIRES_IN=7d            # JWTの有効期限

# ===== ログ =====
LOG_LEVEL=info                 # debug | info | warn | error
